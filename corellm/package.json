{
  "name": "corellm",
  "version": "0.1.0",
  "description": "Shared multi-provider LLM client for the llm-apps packages — one adapter layer with baseUrl proxying, retries, timeouts, and token-usage capture. Framework-agnostic (uses fetch).",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "llm", "ai", "anthropic", "openai", "mistral", "adapter",
    "retries", "streaming", "llm-apps"
  ],
  "author": "roaheit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/roaheit/llm-apps",
    "directory": "corellm"
  }
}
