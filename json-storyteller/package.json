{
  "name": "json-storyteller",
  "version": "1.1.0",
  "description": "A React component that transforms raw JSON into human-readable narratives. Works with any LLM provider — Anthropic, OpenAI, Mistral, or a custom adapter.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "json", "ai", "llm", "anthropic", "openai", "mistral",
    "storyteller", "react", "component", "llm-apps"
  ],
  "author": "roaheit",
  "license": "MIT",
  "dependencies": {
    "corellm": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roaheit/llm-apps",
    "directory": "json-storyteller"
  }
}
