{
  "name": "sql-narrator",
  "version": "0.1.0",
  "description": "A React component that explains SQL queries and their results in plain English — works with any LLM provider.",
  "keywords": ["sql", "llm", "react", "explain", "narrator", "anthropic", "openai", "mistral"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilm-apps/sql-narrator"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
