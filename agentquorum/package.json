{
  "name": "agentquorum",
  "version": "1.0.0",
  "description": "Composable multi-agent reasoning pipeline for React. Define a council of agents with custom roles, choose sequential or parallel orchestration, plug in any LLM — get a live visual reasoning trace.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agentquorum", "multi-agent", "ai", "llm", "reasoning", "anthropic", "openai",
    "mistral", "react", "component", "pipeline", "llm-apps"
  ],
  "author": "roaheit",
  "license": "MIT",
  "dependencies": {
    "corellm": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roaheit/llm-apps.git",
    "directory": "agentquorum"
  }
}
