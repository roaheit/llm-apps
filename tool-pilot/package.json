{
  "name": "tool-pilot",
  "version": "2.0.0",
  "description": "Task-planning AI agent with a ReAct reasoning loop and pluggable tools (web search, code execution, file reading) for React. Give it a goal — watch it think, act, and deliver.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "tool-pilot", "agent", "ai", "llm", "react", "tools", "reasoning",
    "react-loop", "task-planning", "web-search", "code-execution",
    "anthropic", "openai", "mistral", "component", "llm-apps"
  ],
  "author": "roaheit",
  "license": "MIT",
  "dependencies": {
    "llm-core": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roaheit/llm-apps",
    "directory": "tool-pilot"
  }
}
