    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "rollup": "^4.0.0",
    "vite": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ilm-apps/context-forge"
  }
